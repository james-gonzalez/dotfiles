#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$HOME/dotfiles"
BACKUP_DIR="$HOME/dev/dotfiles"

# Detect OS
case "$(uname -s)" in
  Darwin*) OS="mac" ;;
  Linux*)  OS="linux" ;;
  *)       echo "Unsupported OS"; exit 1 ;;
esac

usage() {
  cat <<EOF
Usage: dotfiles <command>

Commands:
  push      Capture current state into the dotfiles repo
              - Dumps Brewfile from Homebrew (macOS)
              - Syncs to backup at $BACKUP_DIR

  pull      Deploy dotfiles from the repo to this machine
              - Stows shared + OS-specific configs
              - Installs Homebrew packages (macOS)
              - Installs tmux plugins

  backup    Sync dotfiles repo to $BACKUP_DIR

  status    Show what's changed in the dotfiles repo

  diff      Show detailed diff of changes

  edit      Open the dotfiles repo in \$EDITOR
EOF
}

log() { printf '\033[1;34m==>\033[0m \033[1m%s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m==> WARNING:\033[0m %s\n' "$*"; }
ok() { printf '\033[1;32m==>\033[0m %s\n' "$*"; }

cmd_push() {
  log "Capturing current state..."

  if [[ "$OS" == "mac" ]] && command -v brew &>/dev/null; then
    log "Dumping Brewfile..."
    brew bundle dump --file="$DOTFILES_DIR/Brewfile" --force --describe
    ok "Brewfile updated"
  fi

  cmd_backup

  log "Status of dotfiles repo:"
  git -C "$DOTFILES_DIR" status --short

  ok "Push complete"
}

cmd_pull() {
  log "Deploying dotfiles..."

  log "Stowing shared + $OS configs..."
  cd "$DOTFILES_DIR"
  stow --restow shared "$OS"
  ok "Configs stowed"

  if [[ "$OS" == "mac" ]] && command -v brew &>/dev/null; then
    log "Installing Homebrew packages..."
    brew bundle install --file="$DOTFILES_DIR/Brewfile" --no-lock
    ok "Homebrew packages installed"
  fi

  if [[ -d "$HOME/.tmux/plugins/tpm" ]]; then
    log "Installing tmux plugins..."
    "$HOME/.tmux/plugins/tpm/bin/install_plugins" || warn "tmux plugin install had issues"
    ok "Tmux plugins installed"
  fi

  ok "Pull complete"
}

cmd_backup() {
  if [[ ! -d "$BACKUP_DIR" ]]; then
    warn "$BACKUP_DIR does not exist, creating..."
    mkdir -p "$BACKUP_DIR"
  fi

  log "Syncing to $BACKUP_DIR..."
  rsync -av --delete --exclude='.git' "$DOTFILES_DIR/" "$BACKUP_DIR/"
  ok "Backup complete"
}

cmd_status() {
  git -C "$DOTFILES_DIR" status
}

cmd_diff() {
  git -C "$DOTFILES_DIR" diff
}

cmd_edit() {
  "${EDITOR:-nvim}" "$DOTFILES_DIR"
}

case "${1:-}" in
  push)   cmd_push ;;
  pull)   cmd_pull ;;
  backup) cmd_backup ;;
  status) cmd_status ;;
  diff)   cmd_diff ;;
  edit)   cmd_edit ;;
  *)      usage ;;
esac
